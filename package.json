{
  "name": "wulture",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npx tsx watch server/src/index.ts",
    "dev:client": "npx vite --config client/vite.config.ts client",
    "build:client": "cd client && npx vite build",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "build": "cd client && npx vite build",
    "build:server": "npx esbuild server/src/index.ts --bundle --platform=node --format=esm --outfile=dist/server.mjs --external:better-sqlite3 --external:@prisma/client --external:@prisma/adapter-better-sqlite3",
    "build:all": "npm run build && npm run build:server",
    "start": "node dist/server.mjs"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.4.0",
    "concurrently": "^9.2.1",
    "prisma": "^7.5.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0"
  }
}
